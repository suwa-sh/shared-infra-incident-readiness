#!/usr/bin/env bash
# siir: shared-infra-incident-readiness CLI entry point.
#
# Runs the Python CLI from source (src/ on PYTHONPATH). The package's runtime
# dependencies — including the separately distributed overlay-scoring-skeleton
# engine — must be installed into the interpreter first, e.g.
#   python3 -m venv .venv && .venv/bin/pip install -e .
# (the engine used to be vendored under src/, so no install was needed; it is
# now a real dependency). After that, `bin/siir <subcommand>` runs the CLI from
# source without reinstalling on every edit. `pip install -e .` also gives you a
# plain `siir` entry point if you prefer.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PYTHON_BIN="${SIIR_PYTHON:-}"
if [ -z "$PYTHON_BIN" ]; then
    if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
        PYTHON_BIN="$REPO_ROOT/.venv/bin/python"
    else
        PYTHON_BIN="$(command -v python3 || command -v python)"
    fi
fi

if [ -z "$PYTHON_BIN" ]; then
    echo "[siir] python interpreter not found" >&2
    exit 127
fi

export PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"

if ! "$PYTHON_BIN" -c "import overlay_scoring" >/dev/null 2>&1; then
    echo "[siir] missing dependency 'overlay_scoring' in $PYTHON_BIN." >&2
    echo "[siir] install it first, e.g.: $REPO_ROOT/.venv from 'pip install -e .'" >&2
    exit 127
fi

exec "$PYTHON_BIN" -m siir.cli "$@"
