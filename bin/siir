#!/usr/bin/env bash
# siir: shared-infra-incident-readiness CLI entry point.
#
# Resolves the repository root from this script's location and runs the Python
# CLI module, so `bin/siir <subcommand>` works from anywhere without installing.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PYTHON_BIN="${SIIR_PYTHON:-}"
if [ -z "$PYTHON_BIN" ]; then
    if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
        PYTHON_BIN="$REPO_ROOT/.venv/bin/python"
    else
        PYTHON_BIN="$(command -v python3 || command -v python)"
    fi
fi

if [ -z "$PYTHON_BIN" ]; then
    echo "[siir] python interpreter not found" >&2
    exit 127
fi

export PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m siir.cli "$@"
